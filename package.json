{
  "name": "manga-gemma-translator",
  "version": "0.4.5",
  "description": "Thin desktop manga translation overlay editor powered by whole-page Gemma 4 OCR and bbox overlays.",
  "license": "MIT",
  "type": "commonjs",
  "main": "out/main/bootstrap.js",
  "scripts": {
    "dev": "node scripts/dev.cjs",
    "build": "node scripts/build.cjs",
    "dist:win": "node scripts/prepare-ocr-python.cjs && node scripts/prepare-flux-klein-runner.cjs && npm run build && electron-builder --config electron-builder.config.cjs --win nsis --x64",
    "compile:electron": "tsc -p tsconfig.electron.json",
    "logs": "node scripts/tail-log.cjs",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "preview": "npm run build && node scripts/preview.cjs",
    "smoke:overlay": "npm run build && node scripts/run-smoke-overlay.cjs",
    "perf:gemma-economy": "npm run build && node scripts/run-gemma-economy-benchmark.cjs"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@radix-ui/react-progress": "^1.1.8",
    "adm-zip": "^0.5.17",
    "openai-oauth": "^1.0.2",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/node": "^25.0.3",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "electron": "^39.2.7",
    "electron-builder": "^26.8.1",
    "typescript": "^5.9.3",
    "vite": "^7.3.0",
    "vitest": "^4.0.16"
  }
}
